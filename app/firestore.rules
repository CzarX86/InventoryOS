rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function canEscalateOwnError() {
      return isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "reportedByUser",
          "reportedAt",
          "ticketId",
          "updatedAt"
        ]);
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function requestOwnerId() {
      return request.resource.data.ownerId;
    }

    function requestAccountId() {
      return request.resource.data.accountId;
    }

    function resourceOwnerId() {
      return resource.data.ownerId;
    }

    function resourceAccountId() {
      return resource.data.accountId;
    }

    function matchesOwnBoundary(ownerId, accountId) {
      return isSignedIn() &&
        ownerId == request.auth.uid &&
        accountId == userDoc().defaultAccountId;
    }

    function canCreateOwnedResource() {
      return matchesOwnBoundary(requestOwnerId(), requestAccountId());
    }

    function canReadOwnedResource() {
      return matchesOwnBoundary(resourceOwnerId(), resourceAccountId());
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() || userId == "demo-user";
    }

    match /inventory/{itemId} {
      allow read, write: if isSignedIn();
    }

    match /telemetry/{logId} {
      allow read, write: if isSignedIn();
    }

    match /system/{docId} {
      allow read, write: if isSignedIn();
    }

    match /usage_stats/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /task_ai_usage/{taskId} {
      allow create: if isSignedIn() && request.resource.data.actorId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    match /ai_runs/{runId} {
      allow create: if canCreateOwnedResource() || request.resource.data.ownerId == "demo-user";
      allow read, update, delete: if isAdmin() || canReadOwnedResource() || resource.data.ownerId == "demo-user";
    }

    match /ai_cost_policies/{policyId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /prompt_templates/{templateId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /style_profiles/{profileId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /whatsapp_instances/{instanceId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /whatsapp_webhook_events/{eventId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /history_backfill_jobs/{jobId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /txt_import_jobs/{jobId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /message_dispatch_jobs/{jobId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /activity_log/{eventId} {
      allow create: if isSignedIn() && request.resource.data.actorId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    match /error_reports/{errorId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if canEscalateOwnError() || isAdmin();
      allow read, delete: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow create: if isSignedIn() &&
        request.resource.data.createdByUserId == request.auth.uid &&
        get(/databases/$(database)/documents/error_reports/$(request.resource.data.errorId)).data.userId == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }

    match /admin_device_tokens/{tokenId} {
      allow create, update: if isAdmin() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin() && resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }

    match /accounts/{accountId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /contacts/{contactId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /contact_channels/{channelId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /conversations/{conversationId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /messages/{messageId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /opportunities/{opportunityId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /contracts/{contractId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /crm_events/{eventId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /tasks/{taskId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /interests/{interestId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /catalog_items/{itemId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /inventory_items/{itemId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /installed_base/{itemId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /maintenance_rules/{ruleId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /item_relationships/{relationshipId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /supplier_accounts/{supplierId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /supplier_contacts/{contactId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /quote_requests/{requestId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /quote_responses/{responseId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /ai_usage_stats/{accountId} {
      allow read: if isAdmin() || canReadOwnedResource();
      allow create, update: if canCreateOwnedResource(); // For simplified accounting
    }

    match /ai_runs/{runId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /supplier_performance_profiles/{profileId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }

    match /procurement_opportunities/{opportunityId} {
      allow create: if canCreateOwnedResource();
      allow read, update, delete: if isAdmin() || canReadOwnedResource();
    }
  }
}
